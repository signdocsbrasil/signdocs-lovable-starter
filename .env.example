# ─────────────────────────────────────────────────────────────────────
# Secrets necessários no Supabase → Edge Functions → Secrets
# ─────────────────────────────────────────────────────────────────────
#
# Este arquivo é apenas referência. Os valores NÃO ficam no projeto
# Lovable ou no git — eles são colados no painel Supabase antes de
# deployar as Edge Functions.

# Credenciais SignDocs Brasil (enviadas pela equipe ao aprovar o tenant)
SIGNDOCS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SIGNDOCS_CLIENT_SECRET=

# URL base do SignDocs
# HML (testes):       https://api-hml.signdocs.com.br   ← ATENÇÃO: hífen
# Produção:           https://api.signdocs.com.br
SIGNDOCS_BASE_URL=https://api-hml.signdocs.com.br

# Secret HMAC do webhook — preenchido DEPOIS de registrar o webhook
# no painel SignDocs. A resposta do POST /v1/webhooks traz o campo
# "secret" uma única vez; copie e cole aqui.
SIGNDOCS_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Os secrets abaixo são injetados automaticamente pelo Supabase em
# Edge Functions. Não precisa configurar manualmente.
# ─────────────────────────────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
